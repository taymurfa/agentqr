*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual environments ─────────────────────────────────
.venv/
venv/
env/

# ─── Environment variables (NEVER commit these) ───────────
.env
.env.local
.env.production
.env.*.local
backend/.env
frontend/.env.local

# ─── API keys & secrets — extra safety net ────────────────
