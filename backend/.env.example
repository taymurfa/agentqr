# ============================================================
# Agentic Quant Researcher — Backend Environment Variables
# Copy this file to .env and fill in your own API keys.
# ============================================================

# LLM — Anthropic (required for all agent reasoning)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# Vector DB — Pinecone (required for RAG & SEC filing search)
# Get key at: https://app.pinecone.io/
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=quant-researcher-local

# Market data — Polygon (optional, Yahoo Finance used as fallback)
# Get key at: https://polygon.io/
POLYGON_API_KEY=xxxxxxxxxxxxxxxx

# Database — SQLite (default for local dev, no setup needed)
# For production: use PostgreSQL — DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///quant_researcher.db

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# SEC EDGAR — set to your name and email (required by EDGAR's fair-use policy)
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Voyage AI — OPTIONAL (only needed if you switch back to cloud embeddings)
# The system uses local fastembed by default so this can stay blank.
VOYAGE_API_KEY=
