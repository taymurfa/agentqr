# ============================================================
# Agentic Quant Researcher — Backend Environment Variables
# Copy this file:  cp .env.example .env
# Then fill in your own values below.
# ============================================================

# ── LLM ──────────────────────────────────────────────────
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Vector DB (Pinecone) ─────────────────────────────────
# Get key: https://app.pinecone.io/
# Create a Serverless index in us-east-1 on AWS (free tier works)
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=quant-researcher

# ── Market Data ──────────────────────────────────────────
# Polygon.io is OPTIONAL — Yahoo Finance is used as the primary fallback.
# Free plan is sufficient. https://polygon.io/
POLYGON_API_KEY=

# ── Database ─────────────────────────────────────────────
# Local development: SQLite (no setup needed — file is created automatically)
DATABASE_URL=sqlite+aiosqlite:///quant_researcher.db
# Production (Railway / Supabase / etc):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── App ──────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── SEC EDGAR ────────────────────────────────────────────
# Required by EDGAR fair-use policy. Use your real name + email.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=Your Name your@email.com
